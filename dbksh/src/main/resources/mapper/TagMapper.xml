<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="scau.dbksh.mapper.TagMapper">

    <select id="selectByNames" resultType="Tag">
        select id,
               name,
               create_time,
               update_time
        from tag
        where name in
        <foreach collection="names" item="name" open="(" separator="," close=")">
            #{name}
        </foreach>
    </select>

    <select id="selectByNameLike" resultType="Tag">
        select id,
               name,
               create_time,
               update_time
        from tag
        where name like concat('%', #{keyword}, '%')
        order by id asc
    </select>

    <select id="selectByName" resultType="Tag">
        select id,
               name,
               create_time,
               update_time
        from tag
        where name = #{name}
    </select>

    <insert id="insertTag" useGeneratedKeys="true" keyProperty="id">
        insert into tag (name)
        values (#{name})
    </insert>
</mapper>
